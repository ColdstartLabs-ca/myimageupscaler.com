e="font-size:14px;line-height:24px;color:#64748b;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">Questions?<!-- --> <a href="mailto:support@myimageupscaler.com" style="color:#3b82f6;text-decoration-line:none;text-decoration:underline" target="_blank">Contact us</a></p><p style="font-size:14px;line-height:24px;color:#64748b;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0"><a href="https://myimageupscaler.com/api/campaigns/unsubscribe?token=test-unsubscribe-token-123" style="color:#3b82f6;text-decoration-line:none;text-decoration:underline" target="_blank">Unsubscribe from marketing emails</a></p><p style="font-size:14px;line-height:24px;color:#64748b;margin:4px 0;margin-top:4px;margin-right:0;margin-bottom:4px;margin-left:0">© <!-- -->2026<!-- --> <!-- -->MyImageUpscaler<!-- -->. All rights reserved.</p></td></tr></tbody></table></td></tr></tbody></table></td></tr></tbody></table></body></html><!--/$-->"`;

exports[`Campaign Email Templates > Non-Uploader Templates > OneClickTryEmail > should render with default props 1`] = `"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd"><!--$--><html dir="ltr" lang="en"><head><meta content="text/html; charset=UTF-8" http-equiv="Content-Type"/><meta name="x-apple-disable-message-reformatting"/></head><body style="background-color:#f6f9fc"><table border="0" width="100%" cellPadding="0" cellSpacing="0" role="presentation" align="center"><tbody><tr><td style="background-color:#f6f9fc;font-family:-apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, Roboto, sans-serif"><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="max-width:600px;margin:0 auto;background-color:#ffffff"><tbody><tr style="width:100%"><td><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background-color:#3b82f6;padding:24px;text-align:center"><tbody><tr><td><p style="font-size:24px;line-height:24px;color:#ffffff;font-weight:bold;margin:0;margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">MyImageUpscaler</p></td></tr></tbody></table><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding:32px 24px"><tbody><tr><td><p style="font-size:24px;line-height:24px;font-weight:bold;color:#0f172a;margin-bottom:16px;margin-top:16px">Try It With One Click</p><p style="font-size:16px;line-height:24px;color:#334155;margin-bottom:16px;margin-top:16px">Hi <!-- -->Test User<!-- -->,</p><p style="font-size:16px;line-height:24px;color:#334155;margin-bottom:16px;margin-top:16px">Still haven&#x27;t tried AI upscaling? We&#x27;ve made it easier than ever. No need to find an image - we&#x27;ve got a sample ready for you.</p><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="background-color:#f0f